{
  "name": "@voicesecure/mobile",
  "private": true,
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm test",
    "test": "npm run test:unit && npm run test:screen",
    "test:unit": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test test/*.test.ts",
    "test:screen": "jest --runInBand"
  },
  "dependencies": {
    "@reduxjs/toolkit": "2.12.0",
    "expo": "57.0.2",
    "expo-audio": "~57.0.2",
    "expo-file-system": "~57.0.1",
    "expo-secure-store": "57.0.0",
    "expo-status-bar": "57.0.0",
    "nativewind": "4.2.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-web": "0.21.2",
    "react-redux": "9.3.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "24.10.1",
    "@types/react": "19.2.17",
    "jest": "^29.7.0",
    "jest-expo": "^57.0.1",
    "tailwindcss": "3.4.19",
    "test-renderer": "^1.2.0",
    "typescript": "6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "<rootDir>/test-screen/**/*.test.tsx"
    ]
  }
}
